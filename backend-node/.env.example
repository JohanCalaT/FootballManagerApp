# ─────────────────────────────────────────────
# FootballManagerApp — Backend Node
# Copia este archivo como .env y rellena los valores
# NUNCA commitees el .env real (está en .gitignore)
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Database — MongoDB
MONGO_URI=

# Firebase Admin SDK (valida JWT del frontend)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# API-Football (plan free: temporadas 2022-2024)
API_FOOTBALL_KEY=
API_FOOTBALL_URL=https://v3.football.api-sports.io

# Azure Blob Storage (imágenes de jugadores)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=

# Azure Key Vault (solo en staging/producción, en local se usa .env)
KEY_VAULT_URL=
