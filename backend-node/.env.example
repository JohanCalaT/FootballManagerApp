# ─────────────────────────────────────────────
# FootballManagerApp — Backend Node
# Copia este archivo como .env y rellena los valores
# NUNCA commitees el .env real (está en .gitignore)
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Database — MongoDB
MONGODB_URI=mongodb://localhost:27017/football-manager

# Cache — Redis (compartido con el backend .NET, prefijo af:*)
# - Bajo Aspire AppHost: lo inyecta automáticamente con formato StackExchange.Redis
#                        (host:port,password=...,ssl=...).
# - Standalone dev:      pon `localhost:6379` (sin password, sin ssl).
# - Si no se define:     el cache arranca en modo NO-OP silencioso (cero crashes,
#                        cero llamadas a Redis, se pega siempre a las APIs externas).
ConnectionStrings__redis=localhost:6379

# Firebase Admin SDK (valida JWT del frontend)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# API-Football (plan free: temporadas 2022-2024)
API_FOOTBALL_KEY=
API_FOOTBALL_URL=https://v3.football.api-sports.io

# Google Gemini (endpoint POST /api/ideal-team)
# Bajo Aspire AppHost se inyecta como GEMINI_API_KEY desde el secret unificado
# (Parameters:GeminiApiKey). Standalone dev: pega tu API key de Google AI Studio.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_MS=30000

# Azure Blob Storage (imágenes de jugadores)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=

# Azure Key Vault (solo en staging/producción, en local se usa .env)
KEY_VAULT_URL=
